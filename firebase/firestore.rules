rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Rooms ─────────────────────────────────────────────────────────────
    match /rooms/{roomCode} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['isPublic','createdAt','createdBy']);
      allow update: if request.auth != null;

      // Messages — any authenticated user can read/write in any room
      match /messages/{msgId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.keys().hasAll(['uid','nick','text','type','ts']);
        // Only author can edit/delete their own messages
        allow update: if request.auth != null && resource.data.uid == request.auth.uid;
        allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
      }

      // Members presence
      match /members/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
        allow delete: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Direct messages ───────────────────────────────────────────────────
    match /dms/{dmId} {
      allow read, write: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;

      match /messages/{msgId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid;
        allow update, delete: if request.auth != null
          && resource.data.uid == request.auth.uid;
      }
    }

    // ── Users ─────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      match /friends/{friendUid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write, delete: if request.auth != null
          && (request.auth.uid == uid || request.auth.uid == friendUid);
      }
      match /friendRequests/{fromUid} {
        allow read, delete: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.uid == fromUid;
      }
      match /invites/{inviteId} {
        allow read, delete: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
