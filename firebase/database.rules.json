{
  "rules": {
    "typing": {
      "$roomCode": {
        ".read":  "auth != null",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.hasChildren(['nick','ts'])"
        }
      }
    },
    "presence": {
      "$roomCode": {
        ".read":  "auth != null",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    ".read":  false,
    ".write": false
  }
}
